{
  "name": "axel-playwright-portfolio",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:staging": "ENV=staging npx playwright test",
    "test:production": "ENV=production npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:ui": "npx playwright test --ui",
    "report": "npx playwright show-report",
    "lint": "eslint . --ext .ts",
    "docker:build": "docker build -t project-1-e2e .",
    "docker:run": "docker compose up --abort-on-container-exit",
    "docker:clean": "docker compose down --volumes",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:happy-path": "playwright test --grep @happy-path",
    "test:negative": "playwright test --grep @negative"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/axl611/axel-playwright-portfolio.git"
  },

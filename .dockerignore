# Dependencies - Docker reinstalls these inside the container
node_modules/

# Git files - not needed inside container
.git/
.gitignore

# Environment files - injected at runtime, not baked into image
.env
.env.staging
.env.production

# Auth state - generated at runtime by tests
.auth/

# Test output - generated inside container, not needed to build it
test-results/
playwright-report/
allure-results/
allure-report/
screenshots/

# TypeScript compiled output
dist/

# VS Code
.vscode/

# OS files
.DS_Store
Thumbs.db

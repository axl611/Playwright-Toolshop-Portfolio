{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "dom"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./",
    "paths": {
      "@pages/*": ["./src/pages/*"],
      "@fixtures/*": ["./src/fixtures/*"],
      "@data/*": ["./src/data/*"],
      "@helpers/*": ["./src/helpers/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "step-definitions/**/*.ts",
    "playwright.config.ts",
    "cucumber.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}